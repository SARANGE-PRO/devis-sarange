rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/quotes/{quoteId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/clients/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/catalogue/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Onglet Compta : paramètres d'export Sage et historique des exports CSV.
    match /users/{userId}/compta/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/comptaExports/{exportId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessions de signature des devis - accessible par utilisateurs authentifiés
    // Le serveur (Admin SDK) peut créer/lire/mettre à jour les sessions
    match /quoteSignatureSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // Collection appartenant à l'AUTRE application (pas l'app devis).
    // Restreinte à votre seul compte pour qu'un autre utilisateur connecté
    // (ex. un collègue de l'app devis) ne puisse pas la lire/écrire.
    match /commandes/{commandeId} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'LKoM5xake1Z1iGJLTHEAh5hXE1n2';
    }
  }
}
